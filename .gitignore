# --- FAISS index artifacts ---
# Rebuildable at any time via `python manage.py build_index --rebuild`,
# and may contain references to local media paths, so it shouldn't be
# committed alongside source code.
modapp/search/indexes/*.index
!modapp/search/indexes/.gitkeep

