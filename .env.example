# ----------------------------------------------------------------------
# ModaMind environment configuration template.
#
# Copy this file to `.env` (which is gitignored) and fill in real values
# for your machine/deployment. NEVER commit your actual .env file.
#
#   cp .env.example .env
# ----------------------------------------------------------------------

# A long, random, unique string. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-a-long-random-string

# Must be "True" for local development only.
# Any deployed / publicly reachable environment MUST set this to "False".
DJANGO_DEBUG=True

# Comma-separated list of hostnames/IPs this site is allowed to serve.
# Add your production domain here when deploying, e.g.:
#   DJANGO_ALLOWED_HOSTS=modamind.example.com,www.modamind.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted https:// origins for CSRF checks. Only
# needed in production when Django sits behind a reverse proxy that
# terminates TLS, e.g.:
#   DJANGO_CSRF_TRUSTED_ORIGINS=https://modamind.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=
