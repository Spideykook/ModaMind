# ----------------------------------------------------------------------
# ModaMind environment configuration template.
#
# Copy this file to `.env` (which is gitignored) and fill in real values
# for your machine/deployment. NEVER commit your actual .env file.
#
#   cp .env.example .env
# ----------------------------------------------------------------------

# A long, random, unique string. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-a-long-random-string

# Must be "True" for local development only.
# Any deployed / publicly reachable environment MUST set this to "False".
DJANGO_DEBUG=True

# Comma-separated list of hostnames/IPs this site is allowed to serve.
# Add your production domain here when deploying, e.g.:
#   DJANGO_ALLOWED_HOSTS=modamind.example.com,www.modamind.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted https:// origins for CSRF checks. Only
# needed in production when Django sits behind a reverse proxy that
# terminates TLS, e.g.:
#   DJANGO_CSRF_TRUSTED_ORIGINS=https://modamind.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# ----------------------------------------------------------------------
# PostgreSQL connection (Phase 3)
# ----------------------------------------------------------------------
# These map directly to Django's DATABASES["default"] dictionary in
# config/settings.py. All have sensible local-development defaults, but
# every deployed environment MUST override at least DB_PASSWORD.
#
# Create the database and role in psql:
#   CREATE DATABASE modamind_db;
#   CREATE USER modamind_user WITH PASSWORD 'your_secure_password';
#   GRANT ALL PRIVILEGES ON DATABASE modamind_db TO modamind_user;

# Name of the PostgreSQL database.
DB_NAME=modamind_db

# PostgreSQL role (username) that owns the database.
DB_USER=modamind_user

# Password for the database role. Empty is acceptable for local peer/trust
# auth, but settings.py will refuse to start with DEBUG=False and no password.
DB_PASSWORD=

# Hostname or IP where PostgreSQL is listening.
#   Local development: localhost
#   Docker Compose:    db  (the service name)
#   AWS RDS / GCP:     your-instance.region.rds.amazonaws.com
DB_HOST=localhost

# PostgreSQL port (default: 5432).
DB_PORT=5432

# Seconds to keep database connections alive between requests (default: 600).
# Set to 0 to close connections after every request (Django's default behavior).
DB_CONN_MAX_AGE=600

# ----------------------------------------------------------------------
# Ollama / LLM configuration (Phase 4)
# ----------------------------------------------------------------------
# FashionReasoningService uses Ollama to run Llama 3 locally for AI
# fashion reasoning.  The LLM layer is optional — set OLLAMA_ENABLED=False
# to disable it entirely (search still works without AI styling advice).
#
# Install Ollama:         https://ollama.com/download
# Pull the model:         ollama pull llama3
# Start the server:       ollama serve

# Base URL for the Ollama REST API.
#   Local development:    http://localhost:11434
#   Remote GPU server:    http://gpu-server:11434
#   Docker Compose:       http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

# Which model to use for fashion reasoning.
# Run "ollama list" to see installed models.
#   Default:  llama3
#   Smaller:  llama3:8b  (faster, less quality)
#   Other:    mistral, gemma, etc.
OLLAMA_MODEL=llama3

# HTTP timeout in seconds for a single LLM generation call.
# LLM inference is slow (5-30s typical). First call may take 60s+
# while the model loads from disk into memory.
OLLAMA_TIMEOUT=120

# Sampling temperature (0.0 = deterministic, 1.0 = very creative).
# 0.7 balances coherent fashion advice with variety.
OLLAMA_TEMPERATURE=0.7

# Feature toggle.  Set to "False" to disable AI reasoning entirely.
# Useful during development, testing, or if Ollama is not installed.
OLLAMA_ENABLED=True
